# Copy to `.env` and edit. Never commit `.env` (it is gitignored).
#
# docker compose --profile … / Postgres container
POSTGRES_USER=water_etl_app
POSTGRES_PASSWORD=replace-with-a-strong-secret
POSTGRES_DB=water_db
POSTGRES_PUBLISH_PORT=5432

# Same credentials are passed to the ETL app as WATER_ETL_DB_* via docker-compose.yml.
# For local (non-Docker) PostgreSQL, you can set the following explicitly instead of POSTGRES_*:
# WATER_ETL_DB_USER=
# WATER_ETL_DB_PASSWORD=
#
# JDBC (optional if you set host/port/db below)
# WATER_ETL_JDBC_URL=jdbc:postgresql://localhost:5432/water_db
#
# Host/port/database for JDBC URL construction and psycopg2 (local dev)
# WATER_ETL_PG_HOST=localhost
# WATER_ETL_PG_PORT=5432
# WATER_ETL_PG_DB=water_db

# Set to 1 only when loading to PostgreSQL (docker-compose sets this for the `etl` service).
# WATER_ETL_USE_POSTGRES=0

# Optional: pin Spark Maven coordinates for the Postgres JDBC driver (default is set in code when USE_POSTGRES=1)
# WATER_ETL_PG_JDBC_PACKAGE=org.postgresql:postgresql:42.7.4
# SPARK_JARS_PACKAGES=org.postgresql:postgresql:42.7.4
